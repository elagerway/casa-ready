{
  "name": "casa-ready",
  "version": "0.3.1",
  "description": "Open-source toolkit to pass Google CASA Tier 2 security assessments without consulting-firm costs.",
  "type": "module",
  "bin": {
    "casa-ready": "./bin/casa-ready.js"
  },
  "types": "./types/index.d.ts",
  "files": [
    "bin/",
    "cli/",
    "configs/",
    "schemas/",
    "types/",
    "scripts/build-schema.js",
    "casa-ready.yml.example",
    "CHANGELOG.md",
    "MIGRATION.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "RUN_INTEGRATION=1 vitest run tests/integration --passWithNoTests",
    "smoke": "node bin/casa-ready.js --help",
    "build:schema": "node scripts/build-schema.js",
    "prepublishOnly": "node scripts/build-schema.js"
  },
  "keywords": [
    "casa",
    "google-oauth",
    "gmail-api",
    "owasp-zap",
    "compliance",
    "security",
    "app-defense-alliance"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elagerway/casa-ready"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "vitest": "^1.6.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "js-yaml": "^4.1.1",
    "zod": "^3.25.76"
  }
}
