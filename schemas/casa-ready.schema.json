{
  "$ref": "#/definitions/CasaReadyConfig",
  "definitions": {
    "CasaReadyConfig": {
      "type": "object",
      "properties": {
        "app": {
          "type": "string",
          "minLength": 1
        },
        "envs": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "targets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "url": {
                      "type": "string",
                      "minLength": 1,
                      "pattern": "^https?:\\/\\/"
                    },
                    "auth": {
                      "anyOf": [
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "form"
                            },
                            "loginUrl": {
                              "$ref": "#/definitions/CasaReadyConfig/properties/envs/additionalProperties/properties/targets/items/properties/url"
                            },
                            "loginRequestBody": {
                              "type": "string",
                              "minLength": 1
                            },
                            "usernameField": {
                              "type": "string",
                              "minLength": 1
                            },
                            "passwordField": {
                              "type": "string",
                              "minLength": 1
                            },
                            "loggedInIndicator": {
                              "type": "string",
                              "minLength": 1
                            }
                          },
                          "required": [
                            "type",
                            "loginUrl",
                            "loginRequestBody",
                            "usernameField",
                            "passwordField",
                            "loggedInIndicator"
                          ],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "supabase-jwt"
                            },
                            "loginUrl": {
                              "$ref": "#/definitions/CasaReadyConfig/properties/envs/additionalProperties/properties/targets/items/properties/url"
                            },
                            "apiKey": {
                              "type": "string",
                              "minLength": 1
                            },
                            "refreshSeconds": {
                              "type": "integer",
                              "exclusiveMinimum": 0,
                              "default": 3300
                            }
                          },
                          "required": [
                            "type",
                            "loginUrl",
                            "apiKey"
                          ],
                          "additionalProperties": false
                        }
                      ]
                    }
                  },
                  "required": [
                    "name",
                    "url",
                    "auth"
                  ],
                  "additionalProperties": false
                },
                "minItems": 1
              }
            },
            "required": [
              "targets"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "app",
        "envs"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CASA Ready Config",
  "description": "Schema for casa-ready.yml. See https://github.com/elagerway/casa-ready"
}
