<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<configuration>
  <context>
    <name>{{contextName}}</name>
    <desc>CASA Ready autogenerated context (Supabase JWT auth)</desc>
    <inscope>true</inscope>
    <incregexes>{{originScope}}</incregexes>
    <tech>
      <include>Db</include>
      <include>Language</include>
      <include>OS</include>
      <include>SCM</include>
      <include>WS</include>
    </tech>
    <urlparser>
      <class>org.zaproxy.zap.model.StandardParameterParser</class>
      <config>{"kvps":"&amp;","kvs":"=","struct":[]}</config>
    </urlparser>
    <postparser>
      <class>org.zaproxy.zap.model.StandardParameterParser</class>
      <config>{"kvps":"&amp;","kvs":"=","struct":[]}</config>
    </postparser>
    <!--
      Script-based authentication (ZAP type=4). The auth script lives at
      /zap/configs/supabase-jwt-script.js inside the container (mounted by
      the orchestrator). It performs the Supabase JSON login, extracts the
      access_token from the response, and stores it in a ZAP user variable
      called `token`. Subsequent requests get the token via the
      Authorization header configured on the user.

      pollurl + pollfreq tell ZAP to periodically re-validate the session
      against /auth/v1/user. If that returns 401, ZAP re-runs the auth
      script and refreshes the token transparently. Default refresh is
      55 min (3300s) — comfortably under Supabase's 1-hour JWT expiry.

      Two substitution layers in this template:
      - CASA Ready placeholders (double-brace form) are replaced by renderContext
        at config-render time (substitution happens BEFORE ZAP sees the file).
      - {%token%} is replaced by ZAP at scan time using the token variable
        set by our auth script. ZAP also uses {%username%}/{%password%}
        for credential substitution at scan time.
    -->
    <authentication>
      <type>4</type>
      <strategy>EACH_RESP</strategy>
      <pollurl>{{supabaseAuthBase}}/user</pollurl>
      <polldata></polldata>
      <pollheaders>Authorization: Bearer {%token%}&#10;apikey: {{apiKey}}</pollheaders>
      <pollfreq>{{refreshSeconds}}</pollfreq>
      <pollunits>SECONDS</pollunits>
      <loggedin>"id"</loggedin>
      <script>
        <name>supabase-jwt-auth</name>
        <engine>Oracle Nashorn</engine>
        <type>authentication</type>
      </script>
      <scriptconfig>
        <param name="loginUrl" value="{{loginUrl}}"/>
        <param name="apiKey" value="{{apiKey}}"/>
      </scriptconfig>
    </authentication>
    <users>
      <user>1;true;{{username}};6;loginUrl={{loginUrl}}~apiKey={{apiKey}}~Username={{username}}~Password={{password}}</user>
    </users>
    <forceduser>1</forceduser>
    <session>
      <type>5</type>
      <httpauthsessionwrapper>
        <name>token</name>
        <header>Authorization</header>
        <value>Bearer {%token%}</value>
      </httpauthsessionwrapper>
    </session>
    <authorization>
      <type>0</type>
      <basic>
        <header></header>
        <body></body>
        <logic>AND</logic>
        <code>-1</code>
      </basic>
    </authorization>
  </context>
</configuration>
