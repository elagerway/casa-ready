<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<configuration>
  <context>
    <name>{{contextName}}</name>
    <desc>CASA Ready autogenerated context (Supabase JWT auth via replacer-injected headers)</desc>
    <inscope>true</inscope>
    <incregexes>{{originScope}}</incregexes>
    <tech>
      <include>Db</include>
      <include>Language</include>
      <include>OS</include>
      <include>SCM</include>
      <include>WS</include>
    </tech>
    <urlparser>
      <class>org.zaproxy.zap.model.StandardParameterParser</class>
      <config>{"kvps":"&amp;","kvs":"=","struct":[]}</config>
    </urlparser>
    <postparser>
      <class>org.zaproxy.zap.model.StandardParameterParser</class>
      <config>{"kvps":"&amp;","kvs":"=","struct":[]}</config>
    </postparser>
    <!--
      v0.2.4 architecture: this context defines scope only. Authentication is
      handled out-of-band: cli/lib/auth/supabase-jwt.js does the Supabase login
      from Node before the scan starts, then injects the resulting JWT (and the
      anon apikey) into every in-scope request via ZAP's replacer addon
      (configured by the orchestrator via -z flags). No <authentication>,
      <users>, or <session> blocks here — those would require a registered
      ZAP script to populate, and the legacy script-based path failed silently
      (zap-baseline.py imports the context BEFORE -z runs, so the context's
      script reference was unresolved and the whole context load returned
      "internal_error", causing an unauthenticated crawl). Pulling auth into
      Node also lets us fail fast with an actionable error if creds are wrong.
    -->
  </context>
</configuration>
